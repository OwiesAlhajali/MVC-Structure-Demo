@model List<NTierTodoApp.Models.TaskItem>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>إدارة المهام – n-tier</title>
    <style>
        .delete-btn {
            color: white;
            background-color: #d9534f;
            border: none;
            padding: 2px 8px;
            cursor: pointer;
            border-radius: 3px;
        }
        .delete-btn:hover {
            background-color: #c9302c;
        }
    </style>
</head>
<body>
    <h1>قائمة المهام (n-tier)</h1>
    <ul>
        @foreach (var task in Model)
        {
            <li style="margin-bottom: 10px;">
                @if(task.IsComplete)
                {
                    <s>@task.Title</s>
                }
                else
                {
                    @task.Title
                    <form method="post" asp-action="CompleteTask" style="display:inline;">
                        <input type="hidden" name="id" value="@task.Id" />
                        <button type="submit">اكتملت</button>
                    </form>
                }

                <form method="post" asp-action="DeleteTask" style="display:inline;">
                    <input type="hidden" name="id" value="@task.Id" />
                    <button type="submit" class="delete-btn" onclick="return confirm('هل أنت متأكد من حذف هذه المهمة؟')">حذف</button>
                </form>
            </li>
        }
    </ul>

    <hr />

    <form method="post" asp-action="AddTask">
        <input type="text" name="title" placeholder="أضف مهمة جديدة" required />
        <button type="submit">إضافة</button>
    </form>
</body>
</html>